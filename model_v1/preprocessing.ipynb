   "source": [
    "df['New_Total'] = df.groupby('Race')['Total Votes Cast'].diff().fillna(df['Total Votes Cast'])\n",
    "df['New_D'] = df.groupby('Race')['D'].diff().fillna(df['D'])\n",
    "\n",
    "df['New_Dem_Prop'] = np.where(\n",
    "    df['New_Total'] > 0, \n",
    "    df['New_D'] / df['New_Total'], \n",
    "    np.nan\n",
    ")\n",
    "\n",
    "df"
   ]
  },
